{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "./dist",
    "resolveJsonModule": true
  },
  "include": [
    "api/**/*",
    "db/**/*",
    "contracts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
